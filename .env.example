# ═══════════════════════════════════════════════════════════════
# 🔐 .env.example — Variáveis de Ambiente
# 
# Copie este arquivo para .env e preencha seus valores
# cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# 🤖 GOOGLE GEMINI (Integração com IA)
# Pegar em: https://makersuite.google.com/app/apikey (FREE)
GEMINI_API_KEY=AIzaSy_sua_chave_aqui

# 🔍 ANTHROPIC (Claude)
# Pegar em: https://console.anthropic.com/account/keys
# ANTHROPIC_API_KEY=sk-ant-sua_chave_aqui

# 🌐 OPENAI (ChatGPT)
# Pegar em: https://platform.openai.com/account/api-keys
# OPENAI_API_KEY=sk-sua_chave_aqui

# 📱 WHATSAPP
# Seu grupo ID no formato: 123456789-1234567890@g.us
# WHATSAPP_GROUP_ID=seu_grupo_aqui

# 🌐 API
# Porta que o servidor Express vai rodar
API_PORT=3000

# 🗄️ BANCO DE DADOS
# Caminho do arquivo SQLite (criar automaticamente se não existir)
DATABASE_PATH=./data/database.sqlite

# 🔧 AMBIENTE
# development | production
NODE_ENV=development

# 📊 LOGGING
# Nível de log: debug | info | warn | error
LOG_LEVEL=info

# 📝 NOTIFICAÇÕES
# Email para alertas (opcional)
# ALERT_EMAIL=seu@email.com

# ⏰ SCHEDULER
# Se desabilitar automático: false | true
SCHEDULER_ENABLED=true
